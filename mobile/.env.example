# IMPORTANT: this app runs on a physical device or emulator, NOT on this machine —
# "localhost" refers to the device itself, not your dev machine, so the backend
# will be unreachable and every request will silently time out or fail to connect.
# Use your dev machine's LAN IP instead (e.g. `ipconfig getifaddr en0` on macOS,
# or `ip addr` on Linux) and make sure the phone/emulator is on the same Wi-Fi
# network as this machine. (Only exception: running via `expo start --web`,
# where the app runs in a browser on this machine and "localhost" is correct —
# but that mode also requires the backend's CORS_ORIGINS to allow it.)
EXPO_PUBLIC_API_URL="http://192.168.1.18:3000/api"

# Shared service credential (not a user login) that lets this app skip the analytics
# team's username/password auth — see backend/README.md "Mobile access" for why.
# Must match MOBILE_API_KEY in backend/.env exactly.
EXPO_PUBLIC_MOBILE_API_KEY="replace-with-a-long-random-string"
